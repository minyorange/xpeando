<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:layout_margin="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_titulo_tutorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guía de Atributos"
            android:textColor="@color/xpeando_purple_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <ViewFlipper
            android:id="@+id/view_flipper_tutorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- FUERZA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/fuerza"
                    android:layout_marginBottom="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FUERZA: El Martillo"
                    android:textColor="@color/xpeando_red_negative"
                    android:textStyle="bold"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aumenta tu daño base. Cada hábito positivo o tarea que termines golpeará con más fuerza al Dragón Pereza. ¡Siente el poder!"
                    android:textAlignment="center"
                    android:textColor="@color/xpeando_text_secondary"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- INTELIGENCIA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/inteligencia"
                    android:layout_marginBottom="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INTELIGENCIA: La Mente"
                    android:textColor="@color/xpeando_blue_xp"
                    android:textStyle="bold"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optimiza tu aprendizaje. Gana mucha más Experiencia (XP) por cada acción. ¡Alcanza niveles legendarios en tiempo récord!"
                    android:textAlignment="center"
                    android:textColor="@color/xpeando_text_secondary"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- CONSTITUCION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/constitucion"
                    android:layout_marginBottom="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONSTITUCIÓN: El Escudo"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tu resistencia física. Reduce drásticamente el daño que recibes cuando fallas tus Dailies. ¡Sobrevive a la pereza!"
                    android:textAlignment="center"
                    android:textColor="@color/xpeando_text_secondary"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- PERCEPCION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/percepcion"
                    android:layout_marginBottom="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERCEPCIÓN: El Ojo"
                    android:textColor="@color/xpeando_yellow_gold"
                    android:textStyle="bold"
                    android:textSize="20sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Encuentra tesoros ocultos. Multiplica las Monedas de Oro que recibes. ¡Ideal para llenar tu inventario de objetos épicos!"
                    android:textAlignment="center"
                    android:textColor="@color/xpeando_text_secondary"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

        </ViewFlipper>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_tutorial_anterior"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Atrás"
                android:visibility="invisible"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btn_tutorial_siguiente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Siguiente"
                android:backgroundTint="@color/xpeando_purple_primary"/>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>