<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/app/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_puntos_badge"
    android:backgroundTint="@color/xpeando_purple_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Recompensa Diaria!"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Elige una carta para recibir tu bonus"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Carta 1 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_1"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/xpeando_yellow_gold"
            app:strokeWidth="2dp">
            <ImageView
                android:id="@+id/iv_card_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@drawable/premios"
                android:padding="8dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Carta 2 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_2"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/xpeando_yellow_gold"
            app:strokeWidth="2dp">
            <ImageView
                android:id="@+id/iv_card_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@drawable/premios"
                android:padding="8dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Carta 3 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_3"
            android:layout_width="80dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/xpeando_yellow_gold"
            app:strokeWidth="2dp">
            <ImageView
                android:id="@+id/iv_card_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:src="@drawable/premios"
                android:padding="8dp"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_recompensa_mensaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text=""
        android:textColor="@color/xpeando_yellow_gold"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btn_recompensa_aceptar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="¡Genial!"
        android:visibility="gone" />

</LinearLayout>