<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/habitica_bg_light"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Nueva Misión"
        android:textColor="@color/habitica_purple_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Título de la gesta"
        app:boxStrokeColor="@color/habitica_purple_primary"
        app:hintTextColor="@color/habitica_purple_primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_nombre_tarea_dialogo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Dificultad de la aventura:"
        android:textColor="@color/habitica_text_secondary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/habitica_purple_light"
        app:strokeWidth="1dp">

        <Spinner
            android:id="@+id/spinner_dificultad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="8dp" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancelar_mision"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retirarse"
            android:textColor="@color/habitica_text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_aceptar_mision"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Aceptar Gesta"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>