<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/habitica_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <CheckBox
            android:id="@+id/cb_daily"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/habitica_purple_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_nombre_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre de la Daily"
                android:textColor="@color/habitica_text_main"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_recompensa_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+15 XP | +10"
                android:textColor="@color/habitica_text_secondary"
                android:textSize="12sp"
                app:drawableEndCompat="@drawable/ic_coins_small"
                android:drawablePadding="4dp"
                android:gravity="center_vertical" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_status_daily"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="@color/habitica_text_secondary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>