<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/xpeando_bg_light">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajustes"
        android:textColor="@color/xpeando_purple_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aquí podrás configurar tu cuenta y notificaciones próximamente."
        android:textColor="@color/black"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Zona de Peligro"
        android:textColor="#FF0000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_borrar_cuenta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Borrar Cuenta Permanentemente"
        android:backgroundTint="#FF4444"
        android:textColor="@color/white" />

</LinearLayout>