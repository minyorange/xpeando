<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xpeando_bg_light">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_faq_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/xpeando_purple_dark"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Preguntas Frecuentes (FAQ)"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_faq_title"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pregunta 1: XP -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¿Cómo gano Experiencia (XP)?"
                        android:textStyle="bold"
                        android:textColor="@color/xpeando_purple_primary"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ganarás XP completando Hábitos (+), Dailies y Tareas Únicas. ¡Subir de nivel te otorga puntos de Atributo para mejorar a tu héroe!"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pregunta 2: El Jefe -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¿Cómo derroto al Dragón Pereza?"
                        android:textStyle="bold"
                        android:textColor="@color/xpeando_red_negative"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cada vez que completas una tarea o hábito positivo, infliges daño al jefe. Si logras derrotarlo, recibirás un gran botín de Monedas y XP. ¡El jefe resucitará más fuerte 24h después!"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pregunta 3: Muerte -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¿Qué pasa si mi salud llega a cero?"
                        android:textStyle="bold"
                        android:textColor="@color/xpeando_purple_primary"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Si pierdes toda tu vida, aparecerá el menú de Resurrección. Podrás usar una Poción, pagar Monedas o resucitar gratis con muy poca vida. ¡No cumplir tus Dailies dañará tu salud!"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pregunta 4: Atributos -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¿Para qué sirve cada Atributo?"
                        android:textStyle="bold"
                        android:textColor="@color/xpeando_purple_primary"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="FUERZA: Más daño al jefe.\nINTELIGENCIA: Más experiencia ganada.\nCONSTITUCIÓN: Menos daño recibido.\nPERCEPCIÓN: Más monedas encontradas."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pregunta 5: Racha -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¿Por qué es importante la Racha (🔥)?"
                        android:textStyle="bold"
                        android:textColor="@color/xpeando_yellow_gold"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Mantener tu racha diaria aumenta el multiplicador de recompensas. Si completas tus Dailies varios días seguidos, ¡tus ganancias de Oro y XP se dispararán!"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pregunta 6: Equipo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¿El equipo mejora mis estadísticas?"
                        android:textStyle="bold"
                        android:textColor="@color/xpeando_purple_primary"
                        android:textSize="16sp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="¡Sí! Al equipar objetos desde tu Inventario, sus bonos se sumarán a tus atributos base. Por ejemplo, una espada legendaria aumentará enormemente tu daño de Fuerza."/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>