<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/habitica_purple_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_calavera"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_delete"
        app:tint="@color/habitica_red_negative" />

    <TextView
        android:id="@+id/tv_titulo_muerte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="¡HAS CAÍDO!"
        android:textColor="@color/habitica_red_negative"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_mensaje_muerte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Tus heridas son graves.\nHas perdido parte de tu equipo."
        android:textColor="@color/white"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_resucitar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Resurgir de las cenizas"
        android:textColor="@color/habitica_purple_dark"
        app:backgroundTint="@color/white"
        app:cornerRadius="8dp" />

</LinearLayout>